{
  "__inputs": [{ "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }],
  "title": "DS-01 Churn Intelligence Dashboard",
  "uid": "ds01-churn-v2",
  "version": 1,
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "Churn Risk Distribution",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "targets": [{ "expr": "sum by (risk_label) (churn_predictions_total)", "legendFormat": "{{risk_label}}" }]
    },
    {
      "id": 2,
      "title": "Daily Predictions Volume",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 16, "h": 8 },
      "targets": [{ "expr": "rate(churn_predictions_total[1h])", "legendFormat": "Predictions/hour" }]
    },
    {
      "id": 3,
      "title": "Model AUC Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [{ "expr": "model_auc_score", "legendFormat": "AUC" }],
      "fieldConfig": { "defaults": { "min": 0.7, "max": 1.0, "thresholds": { "steps": [{ "value": 0.80, "color": "green" }, { "value": 0.75, "color": "yellow" }, { "value": 0, "color": "red" }] } } }
    },
    {
      "id": 4,
      "title": "Data Drift Share",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [{ "expr": "data_drift_share", "legendFormat": "Drift %" }],
      "fieldConfig": { "defaults": { "min": 0, "max": 1, "unit": "percentunit", "thresholds": { "steps": [{ "value": 0.2, "color": "red" }, { "value": 0.1, "color": "yellow" }, { "value": 0, "color": "green" }] } } }
    },
    {
      "id": 5,
      "title": "API Latency p99 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{handler='/predict'}[5m])) * 1000", "legendFormat": "/predict p99" },
        { "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{handler='/agent'}[5m])) * 1000",   "legendFormat": "/agent p99" }
      ]
    }
  ]
}
